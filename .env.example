OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
MOCK_AI=false

DATABASE_PATH=./data/operator.sqlite
X_USER_DATA_DIR=./data/x-session
X_HEADLESS=false
X_CDP_PORT=9222

POSTS_PER_DAY=3
REPLIES_PER_DAY=5
POSTING_TIMES=09:00,14:00,18:00
MAX_FEED_POSTS_TO_SCAN=25
MIN_REPLY_SCORE=8

AUTO_POST_ENABLED=false
AUTO_REPLY_ENABLED=false

TOPICS=personal AI operators,local-first automation,practical AI workflows,small useful tools
FORBIDDEN_TOPICS=politics,religion,medical,legal,tragedy,adult,harassment,drama
TONE_STYLE=concise,thoughtful,specific,plainspoken,curious

SCHEDULER_REPLY_INTERVAL_MINUTES=180
SCHEDULER_JITTER_MINUTES=10
